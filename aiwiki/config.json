{
  "name": "Project Wiki",
  "enabled": true,
  "sync_mode": "manual",
  "llm_model": "ollama_cloud/kimi-k2.5",
  "extraction": {
    "max_tokens": 4096,
    "temperature": 0.0,
    "extract_entities": true,
    "extract_concepts": true,
    "generate_links": true
  },
  "ignore_patterns": [
    "*.tmp",
    "*.temp",
    ".DS_Store",
    "Thumbs.db"
  ],
  "max_file_size": 52428800,
  "version": "1.0.0",
  "sources": [
    {
      "path": "SPEC.md",
      "patterns": [
        "SPEC.md"
      ],
      "recursive": false,
      "enabled": true,
      "is_file": true
    },
    {
      "path": "AGENTS.md",
      "patterns": [
        "AGENTS.md"
      ],
      "recursive": false,
      "enabled": true,
      "is_file": true
    },
    {
      "path": "src",
      "patterns": [
        "**/*"
      ],
      "recursive": true,
      "enabled": true,
      "is_file": false
    },
    {
      "path": "crates",
      "patterns": [
        "**/*"
      ],
      "recursive": true,
      "enabled": true,
      "is_file": false
    }
  ],
  "watch_mode": false
}